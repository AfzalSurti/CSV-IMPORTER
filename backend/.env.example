# Neon Postgres connection string.
# Get this from your Neon project dashboard -> Connection Details.
# Use the "pooled" connection string for serverless deployments.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# OpenRouter API key (https://openrouter.ai/keys). You can swap the model
# below for any OpenRouter-hosted OpenAI/Gemini/Claude model.
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AI_MODEL="google/gemini-2.0-flash-001"

# How many CSV rows to send to the model per request.
AI_BATCH_SIZE=25

# Port the Express server listens on.
PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_URL="http://localhost:3000"

# Used in the OpenRouter HTTP-Referer header (optional, cosmetic).
APP_URL="http://localhost:3000"
